rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل دخول المستخدم الفعلي
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة استرداد مستند بيانات المستخدم الحالي من قاعدة البيانات
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // دالة التحقق من امتلاك دور مسؤول (Admin)
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    // دالة التحقق من أن المستخدم هو معلم معتمد ونشط بالدراسة
    function isApprovedTeacher() {
      return isSignedIn() && 
             getUserData().role == 'teacher' && 
             getUserData().status == 'approved';
    }

    // 1. حماية مجموعة المستخدمين (الأدمن والمعلمين)
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && 
                     request.auth.uid == userId &&
                     request.resource.data.role == 'teacher' && 
                     request.resource.data.status == 'pending';
      // السماح للمستخدم بتعديل بياناته بنفسه (المعلم لتعديل بيانات الدفع والملف الشخصي) أو الأدمن
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // 2. حماية مجموعة الطلاب والدارسين
    match /students/{studentId} {
      allow read: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isAdmin() || (isApprovedTeacher() && getUserData().permissions.addStudents == true);
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid && getUserData().permissions.editStudents == true);
      allow delete: if isAdmin();
    }

    // حماية مجموعة طلبات إضافة الطلاب
    match /studentRequests/{requestId} {
      allow read: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isAdmin() || (isApprovedTeacher() && getUserData().permissions.addStudents == true);
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // 3. حماية مجموعة سجل الحصص والاعتمادات
    match /sessions/{sessionId} {
      allow read: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isAdmin() || isApprovedTeacher();
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid && getUserData().permissions.editSessions == true && resource.data.approved == false);
      allow delete: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid && getUserData().permissions.deleteSessions == true && resource.data.approved == false);
    }

    // 4. حماية الإشعارات والمراسلات العامة
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.recipientId == 'all' || resource.data.recipientId == request.auth.uid));
      allow write: if isAdmin();
    }

    // 5. حماية سجل التدقيق والنشاط الأمني
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    // 6. حماية مجموعة الإعدادات العامة للأكاديمية
    match /settings/{settingId} {
      allow read: if settingId == 'academy' || isSignedIn();
      allow write: if isAdmin();
    }

    // 7. حماية مجموعة أرشيف الرواتب
    match /salaryArchive/{archiveId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
